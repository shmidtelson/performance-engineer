---
/**
 * Cycles: system → light → dark → system
 * Default (no storage): follow prefers-color-scheme
 */
---

<button
  type="button"
  id="theme-toggle"
  class="inline-flex size-9 items-center justify-center rounded-xl text-ink-secondary ring-1 ring-inset ring-line transition-[color,background-color,ring-color,transform] duration-200 hover:bg-bg-muted/70 hover:text-ink hover:ring-ink/20 active:scale-[0.98]"
  aria-label="Theme: system"
  title="Theme"
>
  <span data-theme-icon="system" class="hidden" aria-hidden="true">
    <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="2" y="3" width="20" height="14" rx="2"></rect>
      <path d="M8 21h8M12 17v4"></path>
    </svg>
  </span>
  <span data-theme-icon="light" class="hidden" aria-hidden="true">
    <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
    </svg>
  </span>
  <span data-theme-icon="dark" class="hidden" aria-hidden="true">
    <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 14.5A8.5 8.5 0 1 1 9.5 3 7 7 0 0 0 21 14.5z"></path>
    </svg>
  </span>
</button>

<script>
  type ThemePref = "system" | "light" | "dark";
  const STORAGE_KEY = "pc-theme";
  const ORDER: ThemePref[] = ["system", "light", "dark"];

  function getStored(): ThemePref {
    const v = localStorage.getItem(STORAGE_KEY);
    if (v === "light" || v === "dark" || v === "system") return v;
    return "system";
  }

  function systemDark() {
    return window.matchMedia("(prefers-color-scheme: dark)").matches;
  }

  function resolved(pref: ThemePref): "light" | "dark" {
    if (pref === "system") return systemDark() ? "dark" : "light";
    return pref;
  }

  function apply(pref: ThemePref) {
    const mode = resolved(pref);
    document.documentElement.classList.toggle("dark", mode === "dark");
    document.documentElement.dataset.theme = pref;
    const meta = document.querySelector('meta[name="theme-color"]');
    if (meta) meta.setAttribute("content", mode === "dark" ? "#0b1114" : "#f4f7f8");

    const btn = document.getElementById("theme-toggle");
    if (btn) {
      const labels = { system: "Theme: system", light: "Theme: light", dark: "Theme: dark" } as const;
      btn.setAttribute("aria-label", labels[pref]);
      btn.title = labels[pref];
      btn.querySelectorAll("[data-theme-icon]").forEach((el) => {
        el.classList.toggle("hidden", el.getAttribute("data-theme-icon") !== pref);
      });
    }
  }

  function init() {
    const pref = getStored();
    apply(pref);

    document.getElementById("theme-toggle")?.addEventListener("click", () => {
      const current = getStored();
      const next = ORDER[(ORDER.indexOf(current) + 1) % ORDER.length];
      localStorage.setItem(STORAGE_KEY, next);
      apply(next);
    });

    window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
      if (getStored() === "system") apply("system");
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
