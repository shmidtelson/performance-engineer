---
import CtaButton from "./CtaButton.astro";
import { site } from "../data/site";
---

<div
  class="fixed inset-x-0 bottom-0 z-50 border-t border-line bg-bg/95 p-3 backdrop-blur-sm md:hidden"
  role="region"
  aria-label="Book diagnostic"
>
  <CtaButton href="#book" pulse class="w-full" arrow={false}>
    {site.cta}
  </CtaButton>
</div>
<!-- spacer so content isn't hidden behind the bar -->
<div class="h-16 md:hidden" aria-hidden="true"></div>
