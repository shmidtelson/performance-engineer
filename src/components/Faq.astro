---
import { faq } from "../data/site";
---

<section class="border-b border-line" id="faq">
  <div class="mx-auto max-w-content px-5 py-20 md:px-8 md:py-28">
    <p class="text-sm font-medium text-ink-tertiary">FAQ</p>
    <h2 class="font-display mt-3 max-w-2xl text-3xl text-ink md:text-4xl">
      Straight answers before you book.
    </h2>
    <div class="mt-10 max-w-3xl border-t border-line">
      {faq.map((item) => (
        <details class="group border-b border-line py-5">
          <summary class="cursor-pointer list-none text-lg font-medium text-ink marker:content-none [&::-webkit-details-marker]:hidden">
            <span class="flex items-start justify-between gap-4">
              {item.q}
              <span class="mt-1 font-mono text-ink-tertiary transition group-open:rotate-45" aria-hidden="true">+</span>
            </span>
          </summary>
          <p class="mt-3 max-w-2xl leading-relaxed text-ink-secondary">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
})} />
