---
interface Props {
  value: number;
  suffix?: string;
  prefix?: string;
  decimals?: number;
  label: string;
  detail?: string;
}

const { value, suffix = "", prefix = "", decimals = 0, label, detail } = Astro.props;
---

<div class="min-w-0">
  <p
    class="font-mono text-2xl font-semibold tracking-tight text-ink md:text-3xl"
    data-metric-stat
    data-value={value}
    data-decimals={decimals}
    data-prefix={prefix}
    data-suffix={suffix}
  >
    {prefix}{decimals > 0 ? value.toFixed(decimals) : value}{suffix}
  </p>
  <p class="mt-1 text-sm font-medium text-ink-secondary">{label}</p>
  {detail && <p class="mt-0.5 font-mono text-xs text-ink-tertiary">{detail}</p>}
</div>

<script>
  function animateMetrics() {
    // Prefer data-metric-stat so we don't collide with PerfDemo tab buttons (data-metric).
    const nodes = document.querySelectorAll<HTMLElement>("[data-metric-stat]");
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const run = (el: HTMLElement) => {
      el.classList.add("metric-pop");
      const target = Number(el.dataset.value);
      const decimals = Number(el.dataset.decimals || 0);
      const prefix = el.dataset.prefix || "";
      const suffix = el.dataset.suffix || "";
      if (Number.isNaN(target)) return;
      if (reduced) {
        el.textContent = `${prefix}${decimals ? target.toFixed(decimals) : target}${suffix}`;
        return;
      }
      const duration = 900;
      const start = performance.now();
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        const current = target * eased;
        el.textContent = `${prefix}${decimals ? current.toFixed(decimals) : Math.round(current)}${suffix}`;
        if (t < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          run(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      },
      { threshold: 0.4 },
    );

    nodes.forEach((n) => observer.observe(n));
  }

  animateMetrics();
  document.addEventListener("astro:page-load", animateMetrics);
</script>
