---
import ThemeToggle from "./ThemeToggle.astro";
import CtaButton from "./CtaButton.astro";
import { site } from "../data/site";
---

<header class="sticky top-0 z-40 border-b border-line bg-bg/90 backdrop-blur-sm">
  <div class="mx-auto flex max-w-content items-center justify-between gap-4 px-5 py-3.5 md:px-8">
    <a href="#top" class="leading-tight">
      <span class="block text-sm font-semibold tracking-tight text-ink">{site.name}</span>
      <span class="hidden text-xs text-ink-tertiary sm:block">Performance Engineer</span>
    </a>
    <nav class="hidden items-center gap-7 text-sm font-medium text-ink-secondary md:flex" aria-label="Primary">
      <a href="#cases" class="transition-colors hover:text-ink">Cases</a>
      <a href="#how" class="transition-colors hover:text-ink">How I work</a>
      <a href="#offer" class="transition-colors hover:text-ink">Diagnostic</a>
      <a href="#faq" class="transition-colors hover:text-ink">FAQ</a>
    </nav>
    <div class="flex items-center gap-2.5">
      <ThemeToggle />
      <CtaButton href="#book" size="sm" arrow={false} class="!hidden sm:!inline-flex">
        Book free call
      </CtaButton>
    </div>
  </div>
</header>
