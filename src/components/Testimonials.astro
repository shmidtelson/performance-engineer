---
import { testimonials } from "../data/site";
---

<section class="border-b border-line" id="testimonials">
  <div class="reveal mx-auto max-w-content px-5 py-20 md:px-8 md:py-28">
    <p class="text-sm font-medium text-ink-tertiary">What teams say</p>
    <h2 class="font-display mt-3 max-w-2xl text-3xl text-ink md:text-4xl">
      After shipping — quieter on-call, clearer delivery.
    </h2>
    <div class="mt-12 grid gap-10 md:grid-cols-3 md:gap-8">
      {testimonials.map((t, i) => (
        <blockquote
          class:list={[
            "reveal border-t border-line pt-6",
            i === 1 && "reveal-delay-1",
            i === 2 && "reveal-delay-2",
          ]}
        >
          <p class="font-display text-lg leading-snug text-ink md:text-xl">“{t.quote}”</p>
          <footer class="mt-4 text-sm text-ink-tertiary">{t.context}</footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
