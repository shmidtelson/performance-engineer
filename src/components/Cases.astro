---
import CtaButton from "./CtaButton.astro";
import { cases, site } from "../data/site";
---

<section class="border-b border-line" id="cases">
  <div class="reveal mx-auto max-w-content px-5 py-20 md:px-8 md:py-28">
    <p class="text-sm font-medium text-ink-tertiary">Selected work</p>
    <h2 class="font-display mt-3 max-w-2xl text-3xl text-ink md:text-4xl">
      Outcomes measured in latency, throughput, and delivery safety.
    </h2>
    <p class="mt-4 max-w-2xl text-ink-secondary">
      Some employers stay confidential — the numbers don’t.
    </p>

    <div class="mt-14">
      {cases.map((c, i) => (
        <article class:list={["reveal border-t border-line py-10", i === 1 && "reveal-delay-1", i === 2 && "reveal-delay-2"]}>
          <div class="flex flex-col gap-8 lg:flex-row lg:gap-16">
            <div class="lg:w-[42%]">
              <p class="font-mono text-xs text-ink-tertiary">
                {String(i + 1).padStart(2, "0")}
                {c.org && (
                  <>
                    <span class="mx-2 text-line">·</span>
                    {c.org}
                  </>
                )}
              </p>
              <h3 class="font-display mt-2 text-2xl text-ink md:text-[1.65rem]">{c.title}</h3>
              <p class="mt-3 leading-relaxed text-ink-secondary">{c.summary}</p>
            </div>
            <dl class="flex-1 space-y-0">
              {c.metrics.map((m) => (
                <div class="flex items-baseline justify-between gap-4 border-b border-line py-3 last:border-0">
                  <dt class="text-sm text-ink-tertiary">{m.label}</dt>
                  <dd class="font-mono text-sm tabular-nums text-ink">
                    <span class="text-ink-tertiary">{m.before}</span>
                    <span class="mx-2 text-ink-tertiary">→</span>
                    <span class="font-semibold text-ok">{m.after}</span>
                  </dd>
                </div>
              ))}
            </dl>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-6">
      <CtaButton href="#book" pulse>{site.cta}</CtaButton>
    </div>
  </div>
</section>
