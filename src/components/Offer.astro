---
import CtaButton from "./CtaButton.astro";
import { offerAgenda, offerOutcomes, site } from "../data/site";
---

<section class="border-b border-line bg-ink text-bg" id="offer">
  <div class="reveal mx-auto max-w-content px-5 py-20 md:px-8 md:py-28">
    <p class="text-sm font-medium text-bg/50">The offer</p>
    <h2 class="font-display mt-3 max-w-2xl text-3xl text-bg md:text-4xl">
      Free 30-minute diagnostic call
    </h2>
    <p class="mt-4 max-w-2xl text-bg/65">
      You’ll leave with a clear next-step priority list — even if we don’t work together. Not a full audit. Not free implementation.
    </p>

    <div class="mt-12 grid gap-12 border-t border-bg/15 pt-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <h3 class="text-sm font-semibold text-bg/80">What you get</h3>
        <ul class="mt-5 space-y-4">
          {offerOutcomes.map((item) => (
            <li class="border-b border-bg/10 pb-4 text-bg/65 last:border-0">{item}</li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-bg/80">Call agenda</h3>
        <ol class="mt-5 space-y-0">
          {offerAgenda.map((row) => (
            <li class="flex gap-4 border-b border-bg/10 py-3 last:border-0">
              <span class="w-20 shrink-0 font-mono text-sm text-bg/45">{row.time}</span>
              <span class="text-bg/65">{row.item}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <div class="mt-14 border-t border-bg/15 pt-10" id="book">
      <h3 class="font-display text-2xl text-bg">Book your slot</h3>
      <p class="mt-2 max-w-xl text-sm text-bg/55">
        {site.calendlyHint}
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <CtaButton href={site.bookingUrl} variant="inverse" external pulse>
          {site.cta}
        </CtaButton>
        <CtaButton
          href={`mailto:${site.email}?subject=Diagnostic%20call`}
          variant="ghost"
          arrow={false}
          class="!text-bg/70 ring-1 ring-inset ring-bg/20 hover:!bg-bg/5 hover:!text-bg"
        >
          Or email {site.email}
        </CtaButton>
      </div>
    </div>
  </div>
</section>
