---
/**
 * Network atmosphere anchored to the right half of the hero
 * so copy stays readable. Users → edge → api/db/cache.
 */
---

<div class="network-atmosphere pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
  <svg
    class="network-svg absolute inset-0 h-full w-full text-ink"
    viewBox="0 0 1200 720"
    preserveAspectRatio="xMaxYMid slice"
    fill="none"
  >
    <!--
      Node centers (exact):
      users: (620,160) (580,320) (600,480)
      edge:  (820,320)
      api:   (1040,140)  db: (1080,320)  cache: (1040,500)
    -->
    <g class="network-links" stroke="currentColor" stroke-width="1" opacity="0.25">
      <path id="p1" d="M620 160 C 700 160, 760 240, 820 320" />
      <path id="p2" d="M580 320 C 680 320, 740 320, 820 320" />
      <path id="p3" d="M600 480 C 700 460, 760 400, 820 320" />
      <path id="p4" d="M820 320 C 900 260, 980 180, 1040 140" />
      <path id="p5" d="M820 320 C 920 320, 1000 320, 1080 320" />
      <path id="p6" d="M820 320 C 900 380, 980 460, 1040 500" />
      <path id="p7" d="M620 160 C 760 100, 940 100, 1040 140" opacity="0.45" stroke-dasharray="4 8" />
    </g>

    <!-- Users -->
    <g class="network-node" transform="translate(580 120)">
      <circle cx="40" cy="40" r="34" class="node-ring" />
      <g stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.55">
        <circle cx="40" cy="30" r="9" />
        <path d="M22 58c4-12 12-18 18-18s14 6 18 18" />
      </g>
    </g>
    <g class="network-node" transform="translate(540 280)">
      <circle cx="40" cy="40" r="34" class="node-ring" />
      <g stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.55">
        <circle cx="32" cy="28" r="7" />
        <circle cx="50" cy="30" r="7" />
        <path d="M18 58c3-10 9-15 14-15 4 0 7 2 10 5 3-3 6-5 10-5 5 0 11 5 14 15" />
      </g>
    </g>
    <g class="network-node" transform="translate(560 440)">
      <circle cx="40" cy="40" r="34" class="node-ring" />
      <g stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.55">
        <circle cx="40" cy="30" r="9" />
        <path d="M22 58c4-12 12-18 18-18s14 6 18 18" />
        <path d="M54 28h8M58 24v8" opacity="0.7" />
      </g>
    </g>

    <!-- Edge -->
    <g class="network-node" transform="translate(770 270)">
      <circle cx="50" cy="50" r="44" class="node-ring node-ring-accent" />
      <g stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.6">
        <circle cx="50" cy="50" r="16" />
        <path d="M50 34v32M34 50h32" />
        <path d="M39 39l22 22M61 39L39 61" opacity="0.45" />
      </g>
      <text x="50" y="108" text-anchor="middle" class="node-label">edge</text>
    </g>

    <!-- Servers -->
    <g class="network-node" transform="translate(996 96)">
      <circle cx="44" cy="44" r="38" class="node-ring" />
      <g stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.55">
        <rect x="28" y="22" width="32" height="14" rx="2" />
        <rect x="28" y="38" width="32" height="14" rx="2" />
        <rect x="28" y="54" width="32" height="14" rx="2" />
        <circle cx="34" cy="29" r="1.5" fill="currentColor" stroke="none" />
        <circle cx="34" cy="45" r="1.5" fill="currentColor" stroke="none" />
        <circle cx="34" cy="61" r="1.5" fill="currentColor" stroke="none" />
      </g>
      <text x="44" y="98" text-anchor="middle" class="node-label">api</text>
    </g>
    <g class="network-node" transform="translate(1036 276)">
      <circle cx="44" cy="44" r="38" class="node-ring" />
      <g stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.55">
        <ellipse cx="44" cy="28" rx="16" ry="6" />
        <path d="M28 28v20c0 3.5 7 6 16 6s16-2.5 16-6V28" />
        <path d="M28 38c0 3.5 7 6 16 6s16-2.5 16-6" />
        <path d="M28 48c0 3.5 7 6 16 6s16-2.5 16-6" />
      </g>
      <text x="44" y="98" text-anchor="middle" class="node-label">db</text>
    </g>
    <g class="network-node" transform="translate(996 456)">
      <circle cx="44" cy="44" r="38" class="node-ring" />
      <g stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.55">
        <rect x="26" y="26" width="36" height="36" rx="3" />
        <path d="M26 38h36M38 26v36" />
        <circle cx="50" cy="50" r="4" />
      </g>
      <text x="44" y="98" text-anchor="middle" class="node-label">cache</text>
    </g>

    <g class="packets">
      <circle r="4" class="packet packet-slow">
        <animateMotion dur="6.5s" repeatCount="indefinite" begin="0s">
          <mpath href="#p1" />
        </animateMotion>
      </circle>
      <circle r="3.5" class="packet packet-slow">
        <animateMotion dur="7.2s" repeatCount="indefinite" begin="1.2s">
          <mpath href="#p3" />
        </animateMotion>
      </circle>
      <rect width="7" height="7" rx="1" class="packet packet-slow" transform="translate(-3.5 -3.5)">
        <animateMotion dur="6.8s" repeatCount="indefinite" begin="0.8s">
          <mpath href="#p6" />
        </animateMotion>
      </rect>
      <circle r="3.5" class="packet packet-slow">
        <animateMotion dur="7.5s" repeatCount="indefinite" begin="2s" keyPoints="1;0" keyTimes="0;1" calcMode="linear">
          <mpath href="#p5" />
        </animateMotion>
      </circle>

      <circle r="3.5" class="packet packet-fast">
        <animateMotion dur="1.6s" repeatCount="indefinite" begin="0.2s">
          <mpath href="#p2" />
        </animateMotion>
      </circle>
      <circle r="3" class="packet packet-fast">
        <animateMotion dur="1.4s" repeatCount="indefinite" begin="0.5s">
          <mpath href="#p4" />
        </animateMotion>
      </circle>
      <rect width="6" height="6" rx="1" class="packet packet-fast" transform="translate(-3 -3)">
        <animateMotion dur="1.8s" repeatCount="indefinite" begin="0.9s">
          <mpath href="#p5" />
        </animateMotion>
      </rect>
      <circle r="3" class="packet packet-fast">
        <animateMotion dur="1.5s" repeatCount="indefinite" begin="0.3s">
          <mpath href="#p7" />
        </animateMotion>
      </circle>
      <circle r="2.5" class="packet packet-fast">
        <animateMotion dur="1.7s" repeatCount="indefinite" begin="1.1s" keyPoints="1;0" keyTimes="0;1" calcMode="linear">
          <mpath href="#p4" />
        </animateMotion>
      </circle>
      <circle r="3" class="packet packet-fast">
        <animateMotion dur="1.55s" repeatCount="indefinite" begin="0.7s" keyPoints="1;0" keyTimes="0;1" calcMode="linear">
          <mpath href="#p2" />
        </animateMotion>
      </circle>
    </g>
  </svg>
</div>

<style>
  .network-atmosphere {
    opacity: 0.65;
    /* Fade from left (copy) → visible on right (demo) */
    mask-image: linear-gradient(
      105deg,
      transparent 0%,
      transparent 38%,
      black 58%,
      black 100%
    );
    -webkit-mask-image: linear-gradient(
      105deg,
      transparent 0%,
      transparent 38%,
      black 58%,
      black 100%
    );
  }

  .node-ring {
    fill: var(--pc-bg);
    stroke: currentColor;
    stroke-width: 1;
    opacity: 0.4;
    transform-origin: center;
    transform-box: fill-box;
    animation: node-pulse 3.2s ease-in-out infinite;
  }

  .node-ring-accent {
    opacity: 0.5;
    stroke: var(--pc-accent);
    animation-duration: 2.4s;
  }

  .network-node:nth-child(odd) .node-ring {
    animation-delay: -1.2s;
  }

  .network-node:nth-child(3n) .node-ring {
    animation-delay: -2s;
  }

  .node-label {
    fill: currentColor;
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.4;
  }

  .packet-slow {
    fill: #dc2626;
    opacity: 0.8;
  }

  .packet-fast {
    fill: #16a34a;
    opacity: 0.85;
  }

  html.dark .network-atmosphere {
    opacity: 0.5;
  }

  html.dark .packet-slow {
    fill: #f87171;
  }

  html.dark .packet-fast {
    fill: #4ade80;
  }

  @media (prefers-reduced-motion: reduce) {
    .packets {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .network-atmosphere {
      opacity: 0.4;
      mask-image: linear-gradient(to bottom, transparent 0%, black 25%, black 70%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 25%, black 70%, transparent 100%);
    }

    .node-label {
      display: none;
    }
  }
</style>
